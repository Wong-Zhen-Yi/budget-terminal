# pyenv
#   For a library or package, you might want to ignore these files since the Python version is individual to the developer.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you want to have a fixed version of dependencies, you can commit it.
#   If you are building a library, it is better to not commit it.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
# pdm.lock

# PEP 582; used by e.g. pdm
__pypackages__/

